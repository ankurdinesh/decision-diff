OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4o

# Optional: use an OpenAI-compatible provider instead.
# LLM_API_KEY=your_provider_key_here
# LLM_BASE_URL=https://api.your-provider.example/v1
# LLM_MODEL=your-model-name

# Optional: use a custom OpenAI-compatible base URL with OPENAI_API_KEY.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: run without an LLM provider for local demos and smoke tests.
# ANALYSIS_MODE=local

# Optional: use OpenAI first, then fall back to local analysis on quota/rate/provider errors.
# ENABLE_LOCAL_FALLBACK=true
